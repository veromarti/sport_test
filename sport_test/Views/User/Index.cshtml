@model IEnumerable<sport_test.Models.User>

@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="fas fa-users me-2 text-primary"></i>Usuarios</h4>
        <small class="text-muted">Gestión de usuarios del complejo deportivo</small>
    </div>
    <a asp-action="Create" asp-controller="User" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Nuevo Usuario
    </a>
</div>

@if (TempData["message"] != null)
{
    string success = TempData["success"]?.ToString() ?? "True";
    string alertClass = success == "True" ? "alert-success" : "alert-danger";
    string icon = success == "True" ? "fa-circle-check" : "fa-circle-xmark";
    <div class="alert @alertClass alert-dismissible fade show rounded-3 mb-3" role="alert">
        <i class="fas @icon me-2"></i>@TempData["message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>NOMBRE</th>
                        <th>DOCUMENTO</th>
                        <th>CORREO</th>
                        <th>TELÉFONO</th>
                        <th class="text-end pe-4">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="fas fa-users fa-2x mb-2 d-block"></i>No hay usuarios registrados
                            </td>
                        </tr>
                    }
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@user.Id</td>
                            <td class="fw-semibold">@user.Name</td>
                            <td class="text-muted">@user.Document</td>
                            <td class="text-muted">@user.Email</td>
                            <td class="text-muted">@user.Phone</td>
                            <td class="text-end pe-4">
                                <form asp-action="Destroy" asp-controller="User" method="post" class="d-inline">
                                    <input type="hidden" name="Id" value="@user.Id" />
                                    <a asp-action="Show" asp-controller="User" asp-route-id="@user.Id"
                                       class="btn btn-sm btn-outline-info me-1" title="Ver detalle">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-controller="User" asp-route-id="@user.Id"
                                       class="btn btn-sm btn-outline-warning me-1" title="Editar">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar"
                                            onclick="return confirm('¿Está seguro de eliminar este usuario?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
