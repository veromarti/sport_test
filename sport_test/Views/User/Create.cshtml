@model sport_test.Models.User

@{
    ViewData["Title"] = "Nuevo Usuario";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" asp-controller="User" class="btn btn-outline-secondary btn-sm me-3">
        <i class="fas fa-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0"><i class="fas fa-user-plus me-2 text-primary"></i>Nuevo Usuario</h4>
        <small class="text-muted">Registrar un nuevo usuario en el sistema</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Store" asp-controller="User" method="post">
                    <div class="mt-3">
                        <label asp-for="Name" class="form-label fw-semibold">Nombre completo</label>
                        <input asp-for="Name" class="form-control" type="text" placeholder="Ej: Juan Pérez" />
                    </div>
                    <div class="mt-3">
                        <label asp-for="Document" class="form-label fw-semibold">Documento de identidad</label>
                        <input asp-for="Document" class="form-control" type="text" placeholder="Ej: 1234567890" />
                    </div>
                    <div class="mt-3">
                        <label asp-for="Phone" class="form-label fw-semibold">Teléfono</label>
                        <input asp-for="Phone" class="form-control" type="text" placeholder="Ej: 300 123 4567" />
                    </div>
                    <div class="mt-3">
                        <label asp-for="Email" class="form-label fw-semibold">Correo electrónico</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="correo@ejemplo.com" />
                    </div>

                    @if (TempData["message"] != null)
                    {
                        <div class="alert alert-danger rounded-3 mt-3">
                            <i class="fas fa-circle-xmark me-2"></i>@TempData["message"]
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-floppy-disk me-2"></i>Registrar
                        </button>
                        <a asp-action="Index" asp-controller="User" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
