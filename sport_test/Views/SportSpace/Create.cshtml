@model sport_test.Models.SportSpace

@{
    ViewData["Title"] = "Nuevo Espacio Deportivo";
    var spaceTypes = new[] { "Fútbol", "Baloncesto", "Piscina", "Tenis", "Voleibol", "Squash", "Atletismo", "Otro" };
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" asp-controller="SportSpace" class="btn btn-outline-secondary btn-sm me-3">
        <i class="fas fa-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0"><i class="fas fa-plus-circle me-2 text-success"></i>Nuevo Espacio Deportivo</h4>
        <small class="text-muted">Registrar un nuevo espacio en el complejo</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Store" asp-controller="SportSpace" method="post">
                    <div class="mt-3">
                        <label asp-for="Name" class="form-label fw-semibold">Nombre del espacio</label>
                        <input asp-for="Name" class="form-control" type="text" placeholder="Ej: Cancha de Fútbol A" />
                    </div>
                    <div class="mt-3">
                        <label asp-for="Type" class="form-label fw-semibold">Tipo de espacio</label>
                        <select asp-for="Type" class="form-select">
                            <option value="">-- Seleccione un tipo --</option>
                            @foreach (var t in spaceTypes)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>
                    <div class="mt-3">
                        <label asp-for="Capacity" class="form-label fw-semibold">Capacidad (personas)</label>
                        <input asp-for="Capacity" class="form-control" type="number" min="1" placeholder="Ej: 22" />
                    </div>

                    @if (TempData["message"] != null)
                    {
                        <div class="alert alert-danger rounded-3 mt-3">
                            <i class="fas fa-circle-xmark me-2"></i>@TempData["message"]
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-floppy-disk me-2"></i>Registrar
                        </button>
                        <a asp-action="Index" asp-controller="SportSpace" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
