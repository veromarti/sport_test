@model sport_test.Models.Reservation

@{
    ViewData["Title"] = "Nueva Reserva";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" asp-controller="Reservation" class="btn btn-outline-secondary btn-sm me-3">
        <i class="fas fa-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0"><i class="fas fa-calendar-plus me-2 text-primary"></i>Nueva Reserva</h4>
        <small class="text-muted">Crear una nueva reserva de espacio deportivo</small>
    </div>
</div>

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Store" asp-controller="Reservation" method="post">
                    <div class="mt-3">
                        <label asp-for="UserId" class="form-label fw-semibold">Usuario</label>
                        <select asp-for="UserId" asp-items="ViewBag.Users" class="form-select">
                            <option value="">-- Seleccione un usuario --</option>
                        </select>
                    </div>
                    <div class="mt-3">
                        <label asp-for="SportSpaceId" class="form-label fw-semibold">Espacio Deportivo</label>
                        <select asp-for="SportSpaceId" asp-items="ViewBag.Spaces" class="form-select">
                            <option value="">-- Seleccione un espacio --</option>
                        </select>
                    </div>
                    <div class="mt-3">
                        <label asp-for="Date" class="form-label fw-semibold">Fecha</label>
                        <input asp-for="Date" class="form-control" type="date"
                               min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mt-3">
                        <label asp-for="StartTime" class="form-label fw-semibold">Hora de inicio</label>
                        <input asp-for="StartTime" class="form-control" type="time" />
                    </div>
                    <div class="mt-3">
                        <label asp-for="EndTime" class="form-label fw-semibold">Hora de fin</label>
                        <input asp-for="EndTime" class="form-control" type="time" />
                    </div>

                    @if (TempData["message"] != null)
                    {
                        <div class="alert alert-danger rounded-3 mt-3">
                            <i class="fas fa-circle-xmark me-2"></i>@TempData["message"]
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-floppy-disk me-2"></i>Reservar
                        </button>
                        <a asp-action="Index" asp-controller="Reservation" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
