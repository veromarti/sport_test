@model IEnumerable<sport_test.Models.Reservation>

@{
    ViewData["Title"] = "Reservas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="fas fa-calendar-check me-2 text-primary"></i>Reservas</h4>
        <small class="text-muted">Gestión de reservas del complejo deportivo</small>
    </div>
    <a asp-action="Create" asp-controller="Reservation" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Nueva Reserva
    </a>
</div>

@if (TempData["message"] != null)
{
    string success = TempData["success"]?.ToString() ?? "True";
    string alertClass = success == "True" ? "alert-success" : "alert-danger";
    string icon = success == "True" ? "fa-circle-check" : "fa-circle-xmark";
    <div class="alert @alertClass alert-dismissible fade show rounded-3 mb-3" role="alert">
        <i class="fas @icon me-2"></i>@TempData["message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body py-2 px-3">
        <form method="get" asp-action="Index" asp-controller="Reservation" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label mb-1 small fw-semibold">Filtrar por usuario</label>
                <select name="userId" asp-items="ViewBag.Users" class="form-select form-select-sm">
                    <option value="">Todos los usuarios</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label mb-1 small fw-semibold">Filtrar por espacio</label>
                <select name="spaceId" asp-items="ViewBag.Spaces" class="form-select form-select-sm">
                    <option value="">Todos los espacios</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary btn-sm">
                    <i class="fas fa-filter me-1"></i>Filtrar
                </button>
                <a asp-action="Index" asp-controller="Reservation" class="btn btn-outline-secondary btn-sm ms-1">
                    <i class="fas fa-xmark me-1"></i>Limpiar
                </a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">ID</th>
                        <th>USUARIO</th>
                        <th>ESPACIO</th>
                        <th>FECHA</th>
                        <th>INICIO</th>
                        <th>FIN</th>
                        <th>ESTADO</th>
                        <th class="text-end pe-4">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="fas fa-calendar-xmark fa-2x mb-2 d-block"></i>No hay reservas registradas
                            </td>
                        </tr>
                    }
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted">#@r.Id</td>
                            <td class="fw-semibold">@r.User?.Name</td>
                            <td class="text-muted">@r.SportSpace?.Name</td>
                            <td class="text-muted">@r.Date.ToString("dd/MM/yyyy")</td>
                            <td class="text-muted">@r.StartTime.ToString(@"hh\:mm")</td>
                            <td class="text-muted">@r.EndTime.ToString(@"hh\:mm")</td>
                            <td>
                                @if (r.Status == "Activa")
                                {
                                    <span class="badge bg-success">@r.Status</span>
                                }
                                else if (r.Status == "Cancelada")
                                {
                                    <span class="badge bg-danger">@r.Status</span>
                                }
                                else if (r.Status == "Finalizada")
                                {
                                    <span class="badge bg-secondary">@r.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@r.Status</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Show" asp-controller="Reservation" asp-route-id="@r.Id"
                                   class="btn btn-sm btn-outline-info me-1" title="Ver detalle">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-controller="Reservation" asp-route-id="@r.Id"
                                   class="btn btn-sm btn-outline-warning me-1" title="Editar">
                                    <i class="fas fa-pen"></i>
                                </a>
                                @if (r.Status == "Activa")
                                {
                                    <form asp-action="Cancel" asp-controller="Reservation" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger me-1" title="Cancelar reserva"
                                                onclick="return confirm('¿Está seguro de cancelar esta reserva?')">
                                            <i class="fas fa-ban"></i>
                                        </button>
                                    </form>
                                }
                                <form asp-action="Destroy" asp-controller="Reservation" method="post" class="d-inline">
                                    <input type="hidden" name="Id" value="@r.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" title="Eliminar"
                                            onclick="return confirm('¿Está seguro de eliminar esta reserva?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
