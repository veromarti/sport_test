@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center py-5">
    <i class="fas fa-trophy fa-4x text-primary mb-3"></i>
    <h1 class="display-5 fw-bold">Complejo Deportivo</h1>
    <p class="lead text-muted mb-5">Sistema de Gestión de Reservas</p>
</div>

<div class="row g-4 justify-content-center">
    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body text-center p-4">
                <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px">
                    <i class="fas fa-users fa-xl text-primary"></i>
                </div>
                <h5 class="fw-bold">Usuarios</h5>
                <p class="text-muted small">Registra y gestiona los usuarios que realizan reservas en el complejo.</p>
                <a asp-controller="User" asp-action="Index" class="btn btn-primary">
                    <i class="fas fa-arrow-right me-1"></i>Gestionar Usuarios
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body text-center p-4">
                <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px">
                    <i class="fas fa-futbol fa-xl text-success"></i>
                </div>
                <h5 class="fw-bold">Espacios Deportivos</h5>
                <p class="text-muted small">Administra las canchas, piscinas y demás espacios disponibles para reservar.</p>
                <a asp-controller="SportSpace" asp-action="Index" class="btn btn-success">
                    <i class="fas fa-arrow-right me-1"></i>Ver Espacios
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-body text-center p-4">
                <div class="bg-info bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px">
                    <i class="fas fa-calendar-check fa-xl text-info"></i>
                </div>
                <h5 class="fw-bold">Reservas</h5>
                <p class="text-muted small">Crea, consulta y administra todas las reservas del complejo deportivo.</p>
                <a asp-controller="Reservation" asp-action="Index" class="btn btn-info text-white">
                    <i class="fas fa-arrow-right me-1"></i>Ver Reservas
                </a>
            </div>
        </div>
    </div>
</div>
